{
  "ignoreFiles": ["dist/**", "node_modules/**", "src/global.css"],
  "rules": {
    "color-no-invalid-hex": true,
    "color-named": "never",
    "no-duplicate-selectors": true,
    "declaration-no-important": true,

    "declaration-property-unit-disallowed-list": [
      {
        "border-radius": ["px", "rem"],
        "border": ["px"],
        "border-top": ["px"],
        "border-right": ["px"],
        "border-bottom": ["px"],
        "border-left": ["px"],
        "border-width": ["px"],
        "border-top-width": ["px"],
        "border-right-width": ["px"],
        "border-bottom-width": ["px"],
        "border-left-width": ["px"],
        "outline": ["px"],
        "outline-width": ["px"]
      },
      {
        "severity": "error",
        "message": "Hardcoded value in border property — use a var(--border-*) token instead (CLAUDE.md §CSS conventions)"
      }
    ],

    "declaration-property-value-disallowed-list": [
      {
        "font-weight": ["/^[0-9]+$/"]
      },
      {
        "severity": "error",
        "message": "Numeric font-weight — use a type-* utility class or var(--font-weight-*) token instead (CLAUDE.md §CSS conventions)"
      }
    ]
  }
}
